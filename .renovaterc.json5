{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>home-operations/renovate-presets#2.1.0",
    "github>pwyde/home-ops//.renovate/allowedVersions.json5",
    "github>pwyde/home-ops//.renovate/autoMerge.json5",
    "github>pwyde/home-ops//.renovate/groups.json5",
    "github>pwyde/home-ops//.renovate/labels.json5",
    ":automergeBranch",
    ":disableRateLimiting",
    ":semanticCommits",
    ":timezone(Europe/Stockholm)",
  ],
}
