{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Allowed PostgreSQL major release",
      matchDatasources: ["docker"],
      matchPackageNames: ["vchord-scratch", "postgresql", "postgres-backup-local", "postgres-init"],
      allowedVersions: "<=18",
    },
    {
      description: "Custom schedule for frequently updated container digests",
      matchDataSources: ["docker"],
      matchPackageNames: ["/postgresql"],
      matchUpdateTypes: ["digest"],
      schedule: "on the first day of the month",
    },
    {
      description: "Disable new Meilisearch releases",
      matchDatasources: ["docker"],
      matchPackageNames: ["docker.io/getmeili/meilisearch"],
      enabled: false
    },
    {
      description: "Use loose versioning for SearXNG date + commit image tags",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/searxng/searxng"],
      versioning: "loose",
    },
  ],
}
